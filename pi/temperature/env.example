# Copy this to .env and fill in your values.

# ── Required ───────────────────────────────────────────────────────────────────

# Stable device path for your Zooz ZST38LR dongle.
# Find it with:  ls -la /dev/serial/by-id/
# It will look something like:
#   /dev/serial/by-id/usb-Silicon_Labs_Zooz_ZST10_700_Z-Wave_Stick_XXXXXXXX-if00-port0
ZWAVE_DEVICE=/dev/cu.usbserial-533D0042421 

# Random secret for zwave-js-ui session cookies (any long random string)
SESSION_SECRET=turbohoje123

# ── Optional ───────────────────────────────────────────────────────────────────

# Your local timezone (used for log timestamps in zwave-js-ui)
TZ=America/Denver
